LIBRETIME_VERSION=4.5.0

# URL publique de LibreTime (ton domaine avec HTTPS une fois Caddy configuré)
LIBRETIME_PUBLIC_URL=https://radio.computerjazz.club

# Clés secrètes — génère avec : openssl rand -hex 32
LIBRETIME_API_KEY=change_me_run_openssl_rand_hex_32
LIBRETIME_SECRET_KEY=change_me_run_openssl_rand_hex_32

# PostgreSQL
POSTGRES_USER=libretime
POSTGRES_PASSWORD=change_me_run_openssl_rand_hex_16

# RabbitMQ
RABBITMQ_DEFAULT_VHOST=/libretime
RABBITMQ_DEFAULT_USER=libretime
RABBITMQ_DEFAULT_PASS=change_me_run_openssl_rand_hex_16

# Icecast
ICECAST_SOURCE_PASSWORD=change_me_run_openssl_rand_hex_16
ICECAST_ADMIN_PASSWORD=change_me_run_openssl_rand_hex_16
ICECAST_RELAY_PASSWORD=change_me_run_openssl_rand_hex_16

# Chemin vers le fichier de config LibreTime généré
LIBRETIME_CONFIG_FILEPATH=./config.yml
