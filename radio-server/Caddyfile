radio.computerjazz.club {
    # Flux Icecast + status JSON → proxy vers le conteneur icecast
    handle /stream/* {
        uri strip_prefix /stream
        reverse_proxy localhost:8000
        header Access-Control-Allow-Origin "https://computerjazz.club"
        header Access-Control-Allow-Methods "GET, OPTIONS"
    }

    # Interface LibreTime (admin, schedule, API)
    handle {
        reverse_proxy localhost:8080
        header Access-Control-Allow-Origin "https://computerjazz.club"
        header Access-Control-Allow-Methods "GET, OPTIONS"
    }
}
