<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% if title %}{{ title }} | {% endif %}{{ site.name }}</title>
    <meta name="description" content="{% if description %}{{ description }}{% else %}{{ site.description }}{% endif %}">
    <link rel="stylesheet" href="/assets/fonts/jgs/stylesheet.css">
    <link rel="stylesheet" href="/assets/fonts/flor-de-ruina/stylesheet.css">
    <link rel="stylesheet" href="/assets/fonts/bianzhidai/stylesheet.css">
    <link rel="stylesheet" href="/assets/fonts/fungal/stylesheet.css">
    <link rel="stylesheet" href="/assets/css/style.css">
</head>
<body>
    <header class="site-header">
        <nav class="main-nav">
            <h1 class="site-title"><a href="/">{{ site.name }}</a></h1>
            <ul class="nav-links">
                <li><a href="/">Home</a></li>
                <li><a href="/audio/">Audio</a></li>
                <li><a href="/artists/">Artists</a></li>
                <li><a href="/labels/">Labels</a></li>
                <!--<li><a href="/shop/">Shop</a></li>-->
                <li><a href="/radio/">Radio</a></li>
                <li><a href="/about/">About</a></li>
            </ul>
            <div class="nav-cart"></div>
        </nav>
        <marquee behaviour="alternate" direction="left">
            <h1 class="status">
            <b>status:</b>
            &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;
            audio server available via Internet Archive
            &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; | &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;
            radio coming soon...
            &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; | &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;
            </h1>
        </marquee>
    </header>

    <main class="main-content">
        {{ content | safe }}
    </main>

    <footer class="site-footer">
        <p> {{ site.name }} || computer && jazz everywhere </p>
    </footer>

    <div id="footer-player" class="footer-player">
        <audio id="fp-audio"></audio>
        <img id="fp-cover-img" class="fp-cover-img" src="" alt="">
        <div class="fp-info">
            <span id="fp-track-title" class="fp-track-title">---</span>
            <span id="fp-album-title" class="fp-album-title">---</span>
        </div>
        <div class="fp-controls">
            <button id="fp-shuffle" class="fp-mode-btn" title="Shuffle">~?</button>
            <button id="fp-prev" title="Previous">|◀</button>
            <button id="fp-play" title="Play/Pause">▶</button>
            <button id="fp-next" title="Next">▶|</button>
            <button id="fp-loop" class="fp-mode-btn" title="Loop">↺</button>
        </div>
        <div class="fp-bottom-row">
            <span id="fp-progress-area" class="fp-progress-area">
                <span id="fp-progress-bar" class="fp-progress-bar">----------------------------------------</span>
            </span>
            <span id="fp-time" class="fp-time">--:-- / --:--</span>
            <div class="fp-volume">
                <span id="fp-vol-bar" class="fp-vol-bar">/////......</span>
            </div>
        </div>
    </div>

    <script src="/assets/js/footer-player.js"></script>
    <script src="/assets/js/shop.js"></script>
</body>
</html>
