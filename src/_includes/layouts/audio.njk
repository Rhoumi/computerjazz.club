---
layout: layouts/base.njk
---
<article class="album">
    <header class="album-header">
        {% if cover %}
        <div class="album-cover-container">
            <img src="{{ cover }}" alt="{{ title }} cover" class="album-cover">
        </div>
        {% endif %}
        <div class="album-info">
            <h1 class="album-title">{{ title }}</h1>
            {% if artists %}
                <p class="album-artists">by
                {% for artistName in artists %}
                    {% set artistSlug = artistName | slugify %}
                    <a href="/artists/{{ artistSlug }}/" class="artist-link">{{ artistName }}</a>{% if not loop.last %}{% if loop.revindex == 2 %} && {% else %}, {% endif %}{% endif %}
                {% endfor %}
                </p>
            {% elif artist %}
                <p class="album-artist">by {{ artist }}</p>
            {% endif %}

            {% if labels %}
                <p class="labels-artists">Released on
                {% for labelsName in labels %}
                    {% set labelsSlug = labelsName | slugify %}
                    <a href="/labels/{{ labelsSlug }}/" class="labels-link">{{ labelsName }}</a>{% if not loop.last %}{% if loop.revindex == 2 %} && {% else %}, {% endif %}{% endif %}
                {% endfor %}
                </p>
            {% elif labels %}
                <p class="labels-artist">Released on {{ labels }}</p>
            {% endif %}

            {% if releaseDate %}<p class="release-date">Date: {{ releaseDate | date("%B %d, %Y") }}</p>{% endif %}
            {% if genre %}
                <p class="genre">Genre:
                {% if genre is iterable and genre is not string %}
                    {{ genre | join(", ") }}
                {% else %}
                    {{ genre }}
                {% endif %}
                </p>
            {% endif %}

            {% if merch and merch.length > 0 %}
            <div class="album-shop-link">
                <a href="/shop{{ page.url | replace('/audio', '') }}" class="btn btn-secondary">View Merchandise</a>
            </div>
            {% endif %}
        </div>
    </header>

    {% if description %}
    <div class="album-description">
        {{ description | markdown | safe }}
    </div>
    {% endif %}

    {% if tracks %}
    <section class="tracklist">
        <h2>Tracks</h2>
        <ol class="tracks">
        {% for track in tracks %}
            <li class="track"
                data-index="{{ loop.index0 }}"
                {% if track.file %}data-file="{{ track.file }}"{% endif %}
                data-title="{{ track.title }}"
                data-album="{{ title }}"
                data-cover="{{ cover }}">
                <div class="track-info">
                    <span class="track-number">{{ loop.index }}.</span>
                    <span class="track-title">{{ track.title }}</span>
                    <span class="track-duration" data-track-duration></span>
                </div>
                {% if track.file %}
                <div class="track-controls"></div>
                {% endif %}
            </li>
        {% endfor %}
        </ol>
    </section>
    {% endif %}

<script>
(function () {
  var charWidth = null;

  function measureCharWidth(el) {
    var probe = document.createElement('span');
    probe.style.cssText = 'visibility:hidden;position:absolute;white-space:nowrap;font-family:' +
      getComputedStyle(el).fontFamily + ';font-size:' + getComputedStyle(el).fontSize;
    probe.textContent = '-'.repeat(20);
    document.body.appendChild(probe);
    var w = probe.getBoundingClientRect().width / 20;
    document.body.removeChild(probe);
    return w || 8.5;
  }

  function animChar(gt, cellIndex) {
    var x = ((gt - cellIndex) % 4 + 4) % 4;
    if (x === 0) return '.';
    if (x === 2) return "'";
    return '\u00b7';
  }

  var trackItems = Array.from(document.querySelectorAll('.track[data-file]'));
  if (trackItems.length === 0) return;

  var playlist = trackItems.map(function (el, i) {
    return { file: el.dataset.file, title: el.dataset.title, album: el.dataset.album || '', cover: el.dataset.cover || '', index: i };
  });

  var globalTime = 0;
  setInterval(function () { globalTime++; }, 100);

  // Build ASCII controls for each track
  trackItems.forEach(function (trackEl, i) {
    var controlsDiv = trackEl.querySelector('.track-controls');
    if (!controlsDiv) return;

    var playLink = document.createElement('a');
    playLink.className = 'ascii-play-btn';
    playLink.textContent = ' \u25b6 Play   ';
    playLink.style.cursor = 'pointer';

    var playBar = document.createElement('span');
    playBar.className = 'ascii-progress';

    var currentCells = 20;

    function rebuildCells(n) {
      currentCells = n;
      playBar.innerHTML = '';
      for (var j = 0; j < n; j++) {
        (function (cellIndex, totalCells) {
          var cell = document.createElement('a');
          cell.textContent = '-';
          cell.style.cursor = 'pointer';
          cell.addEventListener('mousedown', function () {
            var fp = window.FooterPlayer;
            if (!fp) return;
            var pl = fp.getPlaylist();
            var sameAlbum = pl.length > 0 && pl[0] && pl[0].file === playlist[0].file;
            if (!sameAlbum || fp.getCurrentIndex() !== i) {
              fp.play(playlist, i);
            }
            setTimeout(function () {
              if (fp.audio.duration) fp.audio.currentTime = fp.audio.duration / totalCells * cellIndex;
            }, 50);
          });
          playBar.appendChild(cell);
        })(j, n);
      }
    }

    rebuildCells(20);

    var durationSpan = document.createElement('span');
    durationSpan.className = 'ascii-duration';
    durationSpan.textContent = ' --:--/--:--';

    playLink.addEventListener('mousedown', function () {
      var fp = window.FooterPlayer;
      if (!fp) return;
      var pl = fp.getPlaylist();
      var sameTrack = pl.length > 0 && pl[fp.getCurrentIndex()] && pl[fp.getCurrentIndex()].file === playlist[i].file;
      if (sameTrack) {
        fp.audio.paused ? fp.audio.play() : fp.audio.pause();
      } else {
        fp.play(playlist, i);
      }
    });

    var spacer = document.createElement('span');
    spacer.textContent = '\u00a0';
    controlsDiv.appendChild(playLink);
    controlsDiv.appendChild(spacer);
    controlsDiv.appendChild(playBar);
    controlsDiv.appendChild(durationSpan);

    // After layout: measure actual bar width and rebuild dynamically
    requestAnimationFrame(function () {
      if (!charWidth) charWidth = measureCharWidth(controlsDiv);
      function updateCells() {
        var bw = playBar.getBoundingClientRect().width;
        if (bw > 0 && charWidth > 0) {
          var n = Math.max(10, Math.floor(bw / charWidth));
          if (n !== currentCells) rebuildCells(n);
        }
      }
      updateCells();
      if (window.ResizeObserver) {
        var ro = new ResizeObserver(updateCells);
        ro.observe(controlsDiv);
      }
    });
  });

  // Load duration from audio metadata for each track
  trackItems.forEach(function (trackEl) {
    var durSpan = trackEl.querySelector('[data-track-duration]');
    var file = trackEl.dataset.file;
    if (!durSpan || !file) return;
    var tmpAudio = new Audio();
    tmpAudio.preload = 'metadata';
    tmpAudio.addEventListener('loadedmetadata', function () {
      var m = Math.floor(tmpAudio.duration / 60);
      var s = Math.floor(tmpAudio.duration % 60);
      durSpan.textContent = (m < 10 ? '0' : '') + m + ':' + (s < 10 ? '0' : '') + s;
    });
    tmpAudio.src = file;
  });

  // ===== CALLBACKS for footer player =====
  window.onFooterPlayerTimeUpdate = function (currentTime, duration, activeIndex) {
    var fp = window.FooterPlayer;
    var activeFile = (fp && fp.getPlaylist()[activeIndex]) ? fp.getPlaylist()[activeIndex].file : null;
    trackItems.forEach(function (trackEl, i) {
      var playBar = trackEl.querySelector('.ascii-progress');
      var durationSpan = trackEl.querySelector('.ascii-duration');
      var playLink = trackEl.querySelector('.ascii-play-btn');
      if (!playBar) return;

      var cellEls = playBar.querySelectorAll('a');
      var totalCells = cellEls.length;

      if (activeFile && playlist[i].file === activeFile && duration && !isNaN(duration)) {
        var filled = Math.floor((currentTime / duration) * totalCells);
        cellEls.forEach(function (cell, j) {
          cell.textContent = j < filled ? animChar(globalTime, j) : '-';
        });
        if (durationSpan) {
          var fmt = function (s) {
            var m = Math.floor(s / 60), sec = Math.floor(s % 60);
            return (m < 10 ? '0' : '') + m + ':' + (sec < 10 ? '0' : '') + sec;
          };
          durationSpan.textContent = ' ' + fmt(currentTime) + '/' + fmt(duration);
        }
        if (playLink && window.FooterPlayer) {
          playLink.textContent = window.FooterPlayer.audio.paused ? ' \u25b6 Play   ' : 'll Pause  ';
        }
      } else {
        cellEls.forEach(function (c) { c.textContent = '-'; });
        if (playLink) playLink.textContent = ' \u25b6 Play   ';
        if (durationSpan) durationSpan.textContent = ' --:--/--:--';
      }
    });
  };

  window.onFooterPlayerTrackChange = function (activeIndex, activeTrack) {
    var activeFile = activeTrack ? activeTrack.file : null;
    trackItems.forEach(function (trackEl, i) {
      var isActive = activeFile != null && playlist[i].file === activeFile;
      trackEl.classList.toggle('playing', isActive);
      var playLink = trackEl.querySelector('.ascii-play-btn');
      if (playLink) playLink.textContent = isActive ? 'll Pause  ' : ' \u25b6 Play   ';
    });
  };

  // Restore state if already playing from this album (after SPA navigation back)
  if (window.FooterPlayer) {
    var fp = window.FooterPlayer;
    var pl = fp.getPlaylist();
    var idx = fp.getCurrentIndex();
    if (pl.length > 0 && pl[0] && pl[0].file === playlist[0].file) {
      window.onFooterPlayerTrackChange(idx, pl[idx]);
    }
  }
})();
</script>

    <div class="album-content">
        {{ content | safe }}
    </div>
</article>
