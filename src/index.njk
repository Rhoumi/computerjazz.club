---
layout: 'layouts/base.njk'
title: Home
---

{# {% include "partials/bytebeat-player.njk" %} #}

<section class="hero">
    <h1 id="home-title">{{ site.other_name }}</h1>
    <p>digital hub for music</p>
    <div id="ascii-jazz-container"
    style="background: darkGrey;
    width: 644px; height: 140px;
    border: 15px inset black;
    cursor: pointer;
    overflow: hidden;
    position: relative;
    margin: 0 auto;">
      <pre id="ascii-jazz-pre"
      style="margin:0;padding:0;
      font-family:'jgs7','Courier New',monospace;
      font-size:11px;line-height:1;
      color:#ddd;white-space:pre;
      width:644px;height:140px;
      overflow:hidden;text-align:center;
      display:flex;align-items:center;justify-content:center;"></pre>
    </div>
    <small style="display:block;margin-top:4px;">
      <a href="https://adelfaure.net/artware/asciifreejazz/" target="_blank" rel="noopener"
      style="font-size:10px;opacity:0.6;">asciifreejazz by Adel Faure</a>
    </small>
</section>

<section class="featured-audio">
    <h2>latest additions</h2>
    <div class="album-grid">
    {% for audio in collections.audio.slice(0, 6) %}
        <div class="album-card">
            {% if audio.data.cover %}
            <div class="album-card-cover">
                <img src="{{ audio.data.cover }}" alt="{{ audio.data.title }} cover" loading="lazy">
                <div class="album-card-overlay">
                    <a href="{{ audio.url }}" class="view-album-btn">View Album</a>
                </div>
            </div>
            {% endif %}
            <div class="album-card-info">
                <h3><a href="{{ audio.url }}">{{ audio.data.title }}</a></h3>

                {% if audio.data.artists %}
                    <p class="artist">by
                    {% for artistName in audio.data.artists %}
                        {% set artistSlug = artistName | slugify %}
                        <a href="/artists/{{ artistSlug }}/" class="artist-link">{{ artistName }}</a>{% if not loop.last %}{% if loop.revindex == 2 %} && {% else %}, {% endif %}{% endif %}
                    {% endfor %}
                    </p>
                {% elif audio.data.artist %}
                    <p class="artist">{{ audio.data.artist }}</p>
                {% endif %}

                {% if audio.data.labels %}
                    <p class="labels-artists">Released on
                    {% for labelsName in audio.data.labels %}
                        {% set labelsSlug = labelsName | slugify %}
                        <a href="/labels/{{ labelsSlug }}/" class="labels-link">{{ labelsName }}</a>{% if not loop.last %}{% if loop.revindex == 2 %} && {% else %}, {% endif %}{% endif %}
                    {% endfor %}
                    </p>
                {% elif audio.data.labels %}
                    <p class="labels-artist">Released on {{ audio.data.labels }}</p>
                {% endif %}

                {% if audio.data.releaseDate %}<p class="release-date">{{ audio.data.releaseDate | date("%Y") }}</p>{% endif %}
            </div>
        </div>
    {% endfor %}
    </div>

    <div class="view-all-audio">
        <a href="/audio/" class="btn btn-primary">View All Audio</a>
    </div>
</section>


<script>
(function () {
  const FONTS = [
    'FlorDeRuina-Germen', 'FlorDeRuina-Semilla', 'FlorDeRuina-Flor',
    'FlorDeRuina-Ruina', 'FlorDeRuina-Fractura',
    'jgs5', 'jgs7', 'jgs9',
    'bianzhidai-Base', 'bianzhidai-Brush', 'bianzhidai-Bubble',
    'bianzhidai-Cloud', 'bianzhidai-Cube', 'bianzhidai-Messier',
    'bianzhidai-Messy', 'bianzhidai-Pearl', 'bianzhidai-Ring',
    'bianzhidai-Stitches',
    'FungalVF'
  ];

  function randFont() {
    const f = FONTS[Math.floor(Math.random() * FONTS.length)];
    // Variable font: randomise GROW (0–1000) and THCK (500–1000)
    const variation = f === 'FungalVF'
      ? `'GROW' ${Math.floor(Math.random() * 1001)}, 'THCK' ${Math.random() < 0.5 ? 500 : 1000}`
      : null;
    return { family: f, variation };
  }

  function applyFont(el, { family, variation }) {
    el.style.fontFamily = "'" + family + "', serif";
    el.style.fontVariationSettings = variation || 'normal';
  }

  const title = document.getElementById('home-title');
  const text  = title.textContent;

  // 10% chance: font different per character
  if (Math.random() < 0.1) {
    title.textContent = '';
    title.setAttribute('aria-label', text);
    for (const char of text) {
      if (char === ' ') {
        title.appendChild(document.createTextNode(' '));
      } else {
        const span = document.createElement('span');
        span.textContent = char;
        span.style.display = 'inline-block';
        applyFont(span, randFont());
        title.appendChild(span);
      }
    }
  } else {
    applyFont(title, randFont());
  }
})();

(function () {
  const container = document.getElementById('ascii-jazz-container');
  const pre = document.getElementById('ascii-jazz-pre');

  let audioCtx = null;
  let workletNode = null;
  let started = false;
  let playing = false;

  function computeGrid() {
    const probe = document.createElement('span');
    const cs = getComputedStyle(pre);
    probe.style.cssText =
      'position:absolute;visibility:hidden;white-space:pre;font-family:' +
      cs.fontFamily + ';font-size:' + cs.fontSize + ';line-height:' + cs.lineHeight;
    probe.textContent = 'x'.repeat(100) + '\n' + 'x'.repeat(100);
    document.body.appendChild(probe);
    const r = probe.getBoundingClientRect();
    document.body.removeChild(probe);
    const charW = r.width / 100;
    const charH = r.height / 2;
    const cols = Math.max(4, Math.floor(container.clientWidth / charW));
    const rows = Math.max(2, Math.floor(container.clientHeight / charH));
    return [cols, rows];
  }

  const processorCode = `
class Sprite {
  constructor(width, height, initFn) {
    this.width = width;
    this.height = height;
    this.data = new Uint32Array(width * height);
    if (initFn) {
      var i = 0;
      for (var y = 0; y < height; y++) {
        for (var x = 0; x < width; x++) {
          this.data[i] = initFn({ i: i, x: x, y: y, sprite: this });
          i++;
        }
      }
    }
  }
  map(fn) {
    var i = 0;
    for (var y = 0; y < this.height; y++) {
      for (var x = 0; x < this.width; x++) {
        this.data[i] = fn({ i: i, x: x, y: y, sprite: this });
        i++;
      }
    }
  }
}

var fps = 24;
var grid = null;
var note = 0;
var playing = false;
var sampleCount = 0;
var frameNum = 0;
var ready = false;

function initGrid(cols, rows) {
  grid = new Sprite(cols, rows, function() { return 32; });
}

function audioSample(t) {
  if (!playing || note === 0) return 0;
  return (t % note < (t / note) % 128) ? 0.25 : 0;
}

function nextFrame() {
  if (!grid) return null;
  note = 0;
  var total = grid.width * grid.height;
  if (Math.random() > 0.995) grid.map(function() { return 0; });
  if (Math.random() > 0.995) grid.map(function() { return 32; });
  grid.map(function(ctx) {
    if (ctx.x === ctx.sprite.width - 1) return 10;
    var d = ctx.sprite.data;
    if (Math.random() < 1 / (total * 10)) return 32 + Math.floor(Math.random() * 96);
    if (Math.random() < 1000 / total && ctx.i > 0 && d[ctx.i - 1] > 32) return d[ctx.i - 1];
    if (Math.random() < 10 / total && ctx.i + 1 < total && d[ctx.i + 1] > 32) return d[ctx.i + 1];
    if (Math.random() < 1 / total && ctx.i + ctx.sprite.width < total && d[ctx.i + ctx.sprite.width] > 32) return d[ctx.i + ctx.sprite.width];
    if (Math.random() < 1 / total && ctx.i - ctx.sprite.width >= 0 && d[ctx.i - ctx.sprite.width] > 32) return d[ctx.i - ctx.sprite.width];
    note += d[ctx.i];
    return d[ctx.i];
  });
  note = ((note / total) % 4 * 100) * 3;
  var copy = new Uint32Array(grid.data);
  return copy.buffer;
}

class AsciiJazzProcessor extends AudioWorkletProcessor {
  constructor() {
    super();
    this.port.onmessage = function(evt) {
      if (evt.data === 'play') { playing = true; return; }
      if (evt.data === 'stop') { playing = false; return; }
      initGrid(evt.data[0], evt.data[1]);
      playing = true;
      ready = true;
    };
  }
  process(inputs, outputs) {
    if (!ready) return true;
    var newFrame = Math.floor(sampleCount / sampleRate * fps);
    if (newFrame !== frameNum) {
      var buf = nextFrame();
      if (buf) this.port.postMessage(buf, [buf]);
      frameNum = newFrame;
    }
    var output = outputs[0];
    for (var i = 0; i < output[0].length; i++) {
      var s = audioSample(sampleCount);
      for (var c = 0; c < output.length; c++) output[c][i] = s;
      sampleCount++;
    }
    return true;
  }
}
registerProcessor('ascii-jazz-proc', AsciiJazzProcessor);
`;

  async function start() {
    started = true;
    playing = true;
    audioCtx = new AudioContext();
    const blob = new Blob([processorCode], { type: 'application/javascript' });
    const url = URL.createObjectURL(blob);
    await audioCtx.audioWorklet.addModule(url);
    URL.revokeObjectURL(url);
    workletNode = new AudioWorkletNode(audioCtx, 'ascii-jazz-proc');
    workletNode.connect(audioCtx.destination);
    workletNode.port.onmessage = function(evt) {
      var data = new Uint32Array(evt.data);
      var str = '';
      for (var i = 0; i < data.length; i++) {
        str += data[i] ? String.fromCharCode(data[i]) : ' ';
      }
      pre.textContent = str;
    };
    var grid = computeGrid();
    workletNode.port.postMessage(grid);
  }

  async function toggle() {
    if (!started) {
      pre.textContent = '';
      await start();
      return;
    }
    playing = !playing;
    workletNode.port.postMessage(playing ? 'play' : 'stop');
    if (playing) audioCtx.resume();
    else audioCtx.suspend();
  }

  container.addEventListener('click', toggle);

  document.addEventListener('keydown', function(e) {
    if (e.target.tagName === 'INPUT' || e.target.tagName === 'TEXTAREA' || e.target.isContentEditable) return;
    if (e.key === 'j' || e.key === 'J') {
      e.preventDefault();
      toggle();
    }
  });

  pre.textContent = 'click or press [J] to jam';
})();
</script>
